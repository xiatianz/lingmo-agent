# AI Gateway Configuration
AI_GATEWAY_API_KEY=your-api-key
AI_GATEWAY_BASE_URL=your-gateway-url

# Model (optional, defaults to @makers/deepseek-v4-flash)
# AI_GATEWAY_MODEL=@makers/deepseek-v4-flash

# Public site URL used for SEO canonical URLs, sitemap, and social previews.
# NEXT_PUBLIC_SITE_URL=https://your-domain.com

# Supabase Auth + encrypted BYOK storage
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_your-key
SUPABASE_SECRET_KEY=sb_secret_your-server-key
USER_KEY_ENCRYPTION_SECRET=replace-with-at-least-32-random-characters

# Platform quota defaults. Users with their own stored model key can bypass
# these limits when BYOK_BYPASS_DAILY_LIMIT=true.
DEFAULT_DAILY_REQUEST_LIMIT=20
DEFAULT_DAILY_TOKEN_LIMIT=100000
BYOK_BYPASS_DAILY_LIMIT=true
ADMIN_EMAILS=admin@example.com

# Web Search API Key (Tencent Cloud WSA)
# Required for the built-in web_search tool. Without this, search falls back
# to no-op (no real results). Obtain from https://console.cloud.tencent.com/
WSA_API_KEY=your-wsa-api-key
